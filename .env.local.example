# ─────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────
# AI Provider — Replicate (replicate.com)
#
# 1. Sign up at replicate.com
# 2. Go to Account → API tokens → copy token
# 3. REPLICATE_MODEL_VERSION — full SHA of the img2img model you choose.
#    Recommended: stability-ai/sdxl (img2img variant)
#    Find it at: replicate.com/stability-ai/sdxl
#    Example SHA: 39ed52f2319f9b10a83e12e09b4e3e9f49d3b7c82dbe24c0f0c02e8e61c2e3a
# ─────────────────────────────────────────────────────
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
REPLICATE_MODEL_VERSION=<paste-model-version-sha-here>

# ─────────────────────────────────────────────────────
# Kaspi Pay (kaspi.kz/business → Merchant cabinet)
#
# 1. Register your business at kaspi.kz/business
# 2. Submit documents and get approved
# 3. In Merchant cabinet: Settings → API → generate credentials
# 4. KASPI_WEBHOOK_SECRET — set a strong random string here
#    AND register the same value in your Merchant cabinet as webhook secret
# ─────────────────────────────────────────────────────
KASPI_MERCHANT_ID=your-merchant-id
KASPI_API_KEY=your-kaspi-api-key
KASPI_WEBHOOK_SECRET=your-random-webhook-secret-min-32-chars

# ─────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
