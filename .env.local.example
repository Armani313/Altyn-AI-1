# ─────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────
# AI Provider — Replicate (replicate.com)
#
# 1. Sign up at replicate.com
# 2. Go to Account → API tokens → copy token
# 3. Choose ONE of the two model reference formats:
#
#    Option A — model slug (easier, works with official models):
#      REPLICATE_MODEL=stability-ai/sdxl
#
#    Option B — version SHA (for any specific version):
#      REPLICATE_MODEL_VERSION=39ed52f2319f9b10a83...
#      Find SHA: replicate.com/stability-ai/sdxl → Versions tab
#
#    REPLICATE_MODEL_VERSION takes priority if both are set.
# ─────────────────────────────────────────────────────
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
REPLICATE_MODEL=stability-ai/sdxl
# REPLICATE_MODEL_VERSION=<paste-sha-here-if-using-specific-version>

# ─────────────────────────────────────────────────────
# AI Provider — Topaz Labs Image API
# ─────────────────────────────────────────────────────
TOPAZ_API_KEY=your-topaz-api-key

# ─────────────────────────────────────────────────────
# Polar (Billing — polar.sh)
#
# 1. Create organization at polar.sh
# 2. Settings → Access Tokens → create token
# 3. Create subscription products and one-time top-up packs
# 4. Settings → Webhooks → add endpoint, copy secret
# ─────────────────────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_pat_...
POLAR_WEBHOOK_SECRET=polar_whs_...
POLAR_PRODUCT_ID_STARTER=your-starter-product-id
POLAR_PRODUCT_ID_PRO=your-pro-product-id
POLAR_PRODUCT_ID_BUSINESS=your-business-product-id
POLAR_PRODUCT_ID_TOPUP_25=your-topup-25-product-id
POLAR_PRODUCT_ID_TOPUP_100=your-topup-100-product-id
POLAR_PRODUCT_ID_TOPUP_250=your-topup-250-product-id
# POLAR_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
