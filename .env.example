# ─────────────────────────────────────────────────────────────────────────────
# Nurai AI Studio — Production environment template
#
# Usage:
#   cp .env.example .env
#   # Fill in real values, then:
#   docker-compose build && docker-compose up -d
#
# Variable types:
#   NEXT_PUBLIC_*  → baked into JS bundle at BUILD time (safe to expose)
#   Everything else → injected at RUNTIME by Docker (never baked in)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Provider — Replicate ───────────────────────────────────────────────────
# Get token: replicate.com → Account → API tokens
# Use ONE of the two model ref formats (VERSION takes priority):
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
REPLICATE_MODEL=stability-ai/sdxl
# REPLICATE_MODEL_VERSION=<sha>

# ── Kaspi Pay ─────────────────────────────────────────────────────────────────
KASPI_MERCHANT_ID=your-merchant-id
KASPI_API_KEY=your-kaspi-api-key
# Minimum 32 chars random string — also register in Kaspi Merchant cabinet
KASPI_WEBHOOK_SECRET=your-random-webhook-secret-min-32-chars

# ── App ───────────────────────────────────────────────────────────────────────
# Set to your real domain (with https) in production
NEXT_PUBLIC_APP_URL=https://studio.nurai.kz
