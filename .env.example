# ─────────────────────────────────────────────────────────────────────────────
# Luminify — Production environment template
#
# Usage:
#   cp .env.example .env
#   # Fill in real values, then:
#   docker-compose build && docker-compose up -d
#
# Variable types:
#   NEXT_PUBLIC_*  → baked into JS bundle at BUILD time (safe to expose)
#   Everything else → injected at RUNTIME by Docker (never baked in)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Provider — Google Gemini ───────────────────────────────────────────────
# Get key: aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Override model (optional, default: gemini-2.5-flash-preview-04-17)
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# ── Polar (Billing) ──────────────────────────────────────────────────────────
# Get token: polar.sh → Settings → Access Tokens
POLAR_ACCESS_TOKEN=polar_pat_...
# Generated when creating webhook endpoint in Polar dashboard
POLAR_WEBHOOK_SECRET=polar_whs_...
# Product IDs from Polar dashboard
POLAR_PRODUCT_ID_STARTER=your-starter-product-id
POLAR_PRODUCT_ID_PRO=your-pro-product-id
POLAR_PRODUCT_ID_BUSINESS=your-business-product-id
# Set to 'sandbox' for testing (default: production)
# POLAR_ENVIRONMENT=production

# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_ID=

# ── App ───────────────────────────────────────────────────────────────────────
# Set to your real domain (with https) in production
NEXT_PUBLIC_APP_URL=https://luminify.app

# ── Cron ──────────────────────────────────────────────────────────────────────
# Secret for /api/cron/cleanup — generate with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret-min-32-chars
# How many days to keep generations before auto-delete (default: 15)
CLEANUP_RETENTION_DAYS=15
